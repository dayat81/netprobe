<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/radio_bg">

    <TextView
        android:id="@+id/permissionBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFF3E0"
        android:padding="12dp"
        android:text="@string/radio_permission_required"
        android:textColor="#E65100"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/radioScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/driveStatusBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/permissionBanner">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <include
                android:id="@+id/rowTech"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowTac"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowEnb"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowCellId"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowArfcn"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowBand"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowRsrp"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowRsrq"
                layout="@layout/item_radio_field" />

            <include
                android:id="@+id/rowSnr"
                layout="@layout/item_radio_field" />

            <LinearLayout
                android:id="@+id/dcNrSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/dcNrHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:paddingBottom="8dp"
                    android:text="@string/radio_dc_nr"
                    android:textColor="@color/radio_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <include
                    android:id="@+id/rowNrPci"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowNrGnb"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowNrCellId"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowNrArfcn"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowNrBand"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowNrRsrp"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowNrRsrq"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowNrSnr"
                    layout="@layout/item_radio_field" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/wifiSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/wifiHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:paddingBottom="8dp"
                    android:text="WIFI"
                    android:textColor="@color/radio_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <include
                    android:id="@+id/rowWifiSsid"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowWifiBssid"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowWifiRssi"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowWifiFrequency"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowWifiLinkSpeed"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowWifiChannel"
                    layout="@layout/item_radio_field" />

                <include
                    android:id="@+id/rowWifiSecurity"
                    layout="@layout/item_radio_field" />
            </LinearLayout>

            <!-- DRIVE ABR LOG -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/driveLogCard"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/log_bg"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:text="DRIVE ABR LOG"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ScrollView
                        android:id="@+id/driveLogScroll"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fillViewport="true"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:id="@+id/driveLogText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="2dp"
                            android:text="Tap Start to begin continuous ABR drive test"
                            android:textColor="@color/text_primary"
                            android:textIsSelectable="true"
                            android:textSize="10sp" />
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Drive status bar -->
    <LinearLayout
        android:id="@+id/driveStatusBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/driveStatusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Drive ABR: idle"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/driveRoundCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 rounds"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Button row -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/lastUpdatedText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/driveButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="▶ Drive"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/radio_start_log"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/lastUpdatedText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textColor="@color/radio_muted"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
